    {
      "id": "2g9A3n6XORCaouDVPcSWL",
      "type": "text",
      "x": 121.04995727539062,
      "y": 1634.5,
      "width": 378.93963623046875,
      "height": 575,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
